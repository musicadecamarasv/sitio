---
const navItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Acerca de', href: '/sobre-nosotros' },
  { label: 'Conciertos', href: '/conciertos' },
  { label: 'Servicios', href: '/servicios' },
  { label: 'Articulos', href: '/blog' },
  { label: 'Contacto', href: '/contacto' },
];
---

<footer class="bg-azul-dark text-blue-200">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <img src="/images/logo-white.png" alt="Sociedad de Musica de Camara de El Salvador" class="h-16 mb-4" />
      </div>

      <!-- Nav -->
      <div>
        <h4 class="text-white font-medium mb-3">Navegacion</h4>
        <nav class="flex flex-col gap-2">
          {navItems.map((item) => (
            <a href={item.href} class="text-sm hover:text-white transition-colors">
              {item.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white font-medium mb-3">Contacto</h4>
        <div class="flex flex-col gap-2 text-sm">
          <a href="tel:+50370424625" class="hover:text-white transition-colors">+503 7042 4625</a>
          <a href="mailto:musicadecamarasv@gmail.com" class="hover:text-white transition-colors">musicadecamarasv@gmail.com</a>
        </div>
      </div>
    </div>

    <div class="border-t border-blue-800 mt-8 pt-8 text-center text-sm">
      <p>Derechos de Autor &copy; {new Date().getFullYear()} Sociedad de Musica de Camara de El Salvador</p>
    </div>
  </div>
</footer>
