---
interface Props {
  title: string;
  subtitle?: string;
  cta?: { label: string; href: string };
  image?: string;
}

const { title, subtitle, cta, image } = Astro.props;
---

<section class="relative bg-azul-dark text-white">
  {image && (
    <div class="absolute inset-0">
      <img src={image} alt="" class="w-full h-full object-cover opacity-40" />
    </div>
  )}
  <div class="relative max-w-6xl mx-auto px-4 py-24 md:py-32">
    <h1 class="text-4xl md:text-5xl font-bold max-w-3xl">{title}</h1>
    {subtitle && <p class="mt-6 text-lg md:text-xl text-gray-300 max-w-2xl">{subtitle}</p>}
    {cta && (
      <a
        href={cta.href}
        class="inline-block mt-8 px-6 py-3 bg-azul hover:bg-blue-700 text-white font-medium rounded-lg transition-colors"
      >
        {cta.label}
      </a>
    )}
  </div>
</section>
