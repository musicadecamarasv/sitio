---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articulos', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<Base title="Artículos" description="Artículos sobre música de cámara en El Salvador y el mundo.">
  <Hero title="Artículos" subtitle="Entrevistas, notas de programa y reflexiones sobre la música de cámara." />

  {articles.length > 0 ? (
    <section class="py-20">
      <div class="max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {articles.map((article) => (
          <a href={`/blog/${article.id}`} class="group block bg-white border border-gray-200 rounded-xl overflow-hidden hover:shadow-lg transition-shadow">
            {article.data.image && (
              <img src={article.data.image} alt={article.data.title} class="w-full h-48 object-cover" />
            )}
            <div class="p-6">
              <time class="text-sm text-gray-500">
                {article.data.publishDate.toLocaleDateString('es-SV', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h3 class="mt-2 text-xl font-semibold group-hover:text-azul transition-colors">{article.data.title}</h3>
              <p class="mt-2 text-gray-600 text-sm">{article.data.excerpt}</p>
              <p class="mt-3 text-sm text-gray-400">Por {article.data.author}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  ) : (
    <section class="py-20">
      <div class="max-w-6xl mx-auto px-4 text-center text-gray-500">
        <p>Próximamente publicaremos artículos sobre música de cámara.</p>
      </div>
    </section>
  )}
</Base>
