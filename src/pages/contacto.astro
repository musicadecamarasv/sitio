---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Newsletter from '../components/Newsletter.astro';
---

<Base title="Contacto" description="Contacta a la Sociedad de Musica de Camara de El Salvador.">
  <Hero
    title="Contactanos"
    subtitle="Estamos aqui para responder tus preguntas y compartir nuestra pasion por la musica de camara en El Salvador."
  />

  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-4">Conectate con nosotros</h2>
      <p class="text-gray-600 mb-8">
        Nos encantaria saber de ti, ya sea para consultas, colaboraciones o simplemente compartir tu amor por la musica.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="p-6 bg-neutral rounded-xl">
          <h3 class="font-semibold text-gray-900 mb-2">Telefono</h3>
          <a href="tel:+50370424625" class="text-azul hover:text-azul-dark">+503 7042 4625</a>
        </div>
        <div class="p-6 bg-neutral rounded-xl">
          <h3 class="font-semibold text-gray-900 mb-2">Correo electronico</h3>
          <a href="mailto:musicadecamarasv@gmail.com" class="text-azul hover:text-azul-dark">musicadecamarasv@gmail.com</a>
        </div>
      </div>
    </div>
  </section>

  <Newsletter />
</Base>
