---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import TeamCard from '../components/TeamCard.astro';
import Newsletter from '../components/Newsletter.astro';

const timeline = [
  {
    year: '2022',
    text: 'Fundacion de la Sociedad, el primer colectivo dedicado exclusivamente a este formato en el pais.',
  },
  {
    year: '2023',
    text: 'Primer concierto en la Gran Sala del Teatro Nacional de San Salvador, con dos funciones agotadas. Primera temporada completa de 12 conciertos.',
  },
  {
    year: '2024',
    text: 'Primer concurso internacional de composicion, con estreno mundial de la pieza ganadora en el MUNA. Estreno mundial de una obra del compositor Josh Rodriguez en el mismo programa. Primera interpretacion en El Salvador de Las Cuatro Estaciones de Vivaldi con cuatro solistas mujeres. Segunda temporada de 12 conciertos.',
  },
  {
    year: '2025',
    text: 'La Sociedad se reinventa mas alla del escenario con el lanzamiento de Colores: una galeria de musica de camara, una serie que explora el concepto del color en la musica a traves de recitales y publicaciones.',
  },
];
---

<Base title="Sobre nosotros" description="Conoce la historia y el equipo de la Sociedad de Musica de Camara de El Salvador.">
  <Hero
    title="La musica de camara, viva en El Salvador"
    subtitle="Somos un colectivo de musicos dedicado a crear, compartir y preservar la experiencia de la musica de camara en El Salvador."
  />

  <!-- Who we are -->
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-3xl font-bold mb-6">Quienes somos</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        La Sociedad de Musica de Camara de El Salvador es un colectivo de musicos salvadorenos fundado en 2022. Usamos la musica de camara como medio para explorar el arte, la conexion humana y la curiosidad, y compartir esa exploracion con el publico.
      </p>
      <p class="text-gray-600 leading-relaxed">
        Creemos que cuando un musico interpreta lo que genuinamente le llena, eso se transmite. No programamos para complacer ni para demostrar versatilidad. Programamos lo que nos despierta algo, confiando en que esa honestidad es lo que crea una experiencia real para quien escucha. Funcionamos como un colectivo con administracion compartida y autonoma. Las decisiones se toman de forma colectiva y cada integrante aporta desde su especialidad. Presentamos conciertos en espacios como el Teatro Nacional de San Salvador, el Museo MARTE y el MUNA, y cada vez mas exploramos la musica de camara mas alla del escenario: desde la creacion, la publicacion y el dialogo con otras disciplinas.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-16 bg-gray-900 text-white">
    <div class="max-w-6xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div>
        <span class="text-4xl font-bold text-amber-400">30+</span>
        <p class="mt-2 text-gray-300">Conciertos realizados</p>
      </div>
      <div>
        <span class="text-4xl font-bold text-amber-400">2</span>
        <p class="mt-2 text-gray-300">Estrenos mundiales</p>
      </div>
      <div>
        <span class="text-4xl font-bold text-amber-400">5+</span>
        <p class="mt-2 text-gray-300">Estrenos nacionales</p>
      </div>
      <div>
        <span class="text-4xl font-bold text-amber-400">25+</span>
        <p class="mt-2 text-gray-300">Musicos participantes</p>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-3xl font-bold mb-12">Nuestra historia</h2>
      <div class="space-y-8 border-l-2 border-amber-300 pl-8">
        {timeline.map((item) => (
          <div class="relative">
            <div class="absolute -left-10 w-4 h-4 bg-amber-500 rounded-full border-2 border-white" />
            <span class="text-amber-700 font-bold text-lg">{item.year}</span>
            <p class="mt-2 text-gray-600 leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Nuestro Equipo</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-12 justify-items-center">
        <TeamCard name="Miguel Berganza" role="Director de Operaciones - Fundador" image="/images/miguel-berganza.jpg" />
        <TeamCard name="Andrea Nolasco" role="Directora de Programacion Artistica" image="/images/andrea-nolasco.jpg" />
        <TeamCard name="Mario Alvarenga" role="Director de Patrimonio y Alianzas" image="/images/mario-alvarenga.jpeg" />
        <TeamCard name="Proximamente" role="" />
      </div>
    </div>
  </section>

  <Newsletter />
</Base>
