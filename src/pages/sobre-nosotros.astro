---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import TeamCard from '../components/TeamCard.astro';
import Newsletter from '../components/Newsletter.astro';

const timeline = [
  {
    year: '2022',
    text: 'Fundación de la Sociedad, el primer colectivo dedicado exclusivamente a este formato en el país.',
  },
  {
    year: '2023',
    text: 'Primer concierto en la Gran Sala del Teatro Nacional de San Salvador, con dos funciones agotadas. Primera temporada completa de 12 conciertos.',
  },
  {
    year: '2024',
    text: 'Primer concurso internacional de composición, con estreno mundial de la pieza ganadora en el MUNA. Estreno mundial de una obra del compositor Josh Rodríguez en el mismo programa. Primera interpretación en El Salvador de Las Cuatro Estaciones de Vivaldi con cuatro solistas mujeres. Segunda temporada de 12 conciertos.',
  },
  {
    year: '2025',
    text: 'La Sociedad se reinventa más allá del escenario con el lanzamiento de Colores: una galería de música de cámara, una serie que explora el concepto del color en la música a través de recitales y publicaciones.',
  },
];
---

<Base title="Sobre nosotros" description="Conoce la historia y el equipo de la Sociedad de Música de Cámara de El Salvador.">
  <Hero
    title="La música de cámara, viva en El Salvador"
    subtitle="Somos un colectivo de músicos dedicado a crear, compartir y preservar la experiencia de la música de cámara en El Salvador."
  />

  <!-- Who we are -->
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-3xl font-bold mb-6">Quiénes somos</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        La Sociedad de Música de Cámara de El Salvador es un colectivo de músicos salvadoreños fundado en 2022. Usamos la música de cámara como medio para explorar el arte, la conexión humana y la curiosidad, y compartir esa exploración con el público.
      </p>
      <p class="text-gray-600 leading-relaxed">
        Creemos que cuando un músico interpreta lo que genuinamente le llena, eso se transmite. No programamos para complacer ni para demostrar versatilidad. Programamos lo que nos despierta algo, confiando en que esa honestidad es lo que crea una experiencia real para quien escucha. Funcionamos como un colectivo con administración compartida y autónoma. Las decisiones se toman de forma colectiva y cada integrante aporta desde su especialidad. Presentamos conciertos en espacios como el Teatro Nacional de San Salvador, el Museo MARTE y el MUNA, y cada vez más exploramos la música de cámara más allá del escenario: desde la creación, la publicación y el diálogo con otras disciplinas.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-16 bg-azul-dark text-white">
    <div class="max-w-6xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div>
        <span class="text-4xl font-bold text-blue-300">30+</span>
        <p class="mt-2 text-blue-200">Conciertos realizados</p>
      </div>
      <div>
        <span class="text-4xl font-bold text-blue-300">2</span>
        <p class="mt-2 text-blue-200">Estrenos mundiales</p>
      </div>
      <div>
        <span class="text-4xl font-bold text-blue-300">5+</span>
        <p class="mt-2 text-blue-200">Estrenos nacionales</p>
      </div>
      <div>
        <span class="text-4xl font-bold text-blue-300">25+</span>
        <p class="mt-2 text-blue-200">Músicos participantes</p>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-3xl font-bold mb-12">Nuestra historia</h2>
      <div class="space-y-8 border-l-2 border-azul/30 pl-8">
        {timeline.map((item) => (
          <div class="relative">
            <div class="absolute -left-10 w-4 h-4 bg-azul rounded-full border-2 border-white" />
            <span class="text-azul-dark font-bold text-lg">{item.year}</span>
            <p class="mt-2 text-gray-600 leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-20 bg-neutral">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Nuestro Equipo</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-12 justify-items-center">
        <TeamCard name="Miguel Berganza" role="Director de Operaciones - Fundador" image="/images/miguel-berganza.jpg" />
        <TeamCard name="Andrea Nolasco" role="Directora de Programación Artística" image="/images/andrea-nolasco.jpg" />
        <TeamCard name="Mario Alvarenga" role="Director de Patrimonio y Alianzas" image="/images/mario-alvarenga.jpeg" />
      </div>
    </div>
  </section>

  <Newsletter />
</Base>
