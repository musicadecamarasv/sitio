---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import TeamCard from '../components/TeamCard.astro';
import Newsletter from '../components/Newsletter.astro';
---

<Base title="Home">
  <Hero
    title="Música de cámara, en vivo, en tu país"
    subtitle="Somos un colectivo de músicos que programa y presenta conciertos de música de cámara en los mejores espacios culturales de El Salvador."
    cta={{ label: 'Ver próximos conciertos', href: '/conciertos' }}
    image="/images/concierto-1.jpg"
  />

  <!-- Services -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Nuestros Servicios</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="p-6 bg-gray-50 rounded-xl">
          <span class="text-azul font-bold text-sm">01</span>
          <h3 class="mt-2 text-xl font-semibold">Temporada de conciertos</h3>
          <p class="mt-3 text-gray-600">
            Presentamos conciertos en espacios como el Teatro Nacional, Museo MARTE y MUNA. Consulta nuestra programación y reserva tus entradas.
          </p>
          <a href="/conciertos" class="inline-block mt-4 text-azul font-medium hover:text-azul-dark">
            Ver conciertos &rarr;
          </a>
        </div>
        <div class="p-6 bg-gray-50 rounded-xl">
          <span class="text-azul font-bold text-sm">02</span>
          <h3 class="mt-2 text-xl font-semibold">Música en vivo para eventos</h3>
          <p class="mt-3 text-gray-600">
            Hacemos tu evento especial con música de cámara en vivo. Bodas, corporativos, cenas privadas.
          </p>
          <a href="/contacto" class="inline-block mt-4 text-azul font-medium hover:text-azul-dark">
            Solicitar cotización &rarr;
          </a>
        </div>
        <div class="p-6 bg-gray-50 rounded-xl">
          <span class="text-azul font-bold text-sm">03</span>
          <h3 class="mt-2 text-xl font-semibold">Tienda en línea</h3>
          <p class="mt-3 text-gray-600">
            Playeras, accesorios y más. Lleva un pedazo de la Sociedad contigo.
          </p>
          <a href="/servicios" class="inline-block mt-4 text-azul font-medium hover:text-azul-dark">
            Visita nuestra tienda &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="py-20 bg-neutral">
    <div class="max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl font-bold">Conócenos</h2>
        <h3 class="mt-4 text-xl font-semibold text-azul">Nuestra historia</h3>
        <p class="mt-4 text-gray-600 leading-relaxed">
          Fundada en 2022, la Sociedad de Música de Cámara reúne a músicos que comparten una curiosidad genuina por este repertorio. Más de 30 conciertos, 25 músicos involucrados y varias obras presentadas por primera vez en El Salvador.
        </p>
        <a
          href="/sobre-nosotros"
          class="inline-block mt-6 px-6 py-3 bg-azul hover:bg-azul-dark text-white font-medium rounded-lg transition-colors"
        >
          Leer más
        </a>
      </div>
      <div class="rounded-xl overflow-hidden">
        <img src="/images/conocenos.jpg" alt="Concierto de música de cámara" class="w-full h-80 object-cover" />
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Nuestro Equipo</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-12 justify-items-center">
        <TeamCard name="Miguel Berganza" role="Director de Operaciones - Fundador" image="/images/miguel-berganza.jpg" />
        <TeamCard name="Andrea Nolasco" role="Directora de Programación Artística" image="/images/andrea-nolasco.jpg" />
        <TeamCard name="Mario Alvarenga" role="Director de Patrimonio y Alianzas" image="/images/mario-alvarenga.jpeg" />
      </div>
    </div>
  </section>

  <Newsletter />
</Base>
