---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const concerts = await getCollection('conciertos');
  return concerts.map((concert) => ({
    params: { id: concert.id },
    props: { concert },
  }));
}

const { concert } = Astro.props;
const { Content } = await render(concert);
const { title, date, time, venue, venueAddress, artists, program, ticketPrice, ticketUrl } = concert.data;
---

<Base title={title} description={`${title} - ${venue}`}>
  <article class="py-20">
    <div class="max-w-3xl mx-auto px-4">
      <a href="/conciertos" class="text-azul hover:text-azul-dark text-sm font-medium">&larr; Todos los conciertos</a>

      <h1 class="mt-6 text-4xl font-bold">{title}</h1>

      <div class="mt-6 flex flex-wrap gap-6 text-gray-600">
        <div>
          <span class="font-medium text-gray-900">Fecha:</span>{' '}
          {date.toLocaleDateString('es-SV', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}
          {time && ` - ${time}`}
        </div>
        <div>
          <span class="font-medium text-gray-900">Lugar:</span> {venue}
          {venueAddress && <span class="text-sm"> ({venueAddress})</span>}
        </div>
      </div>

      {ticketUrl && (
        <a
          href={ticketUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block mt-6 px-6 py-3 bg-azul hover:bg-azul-dark text-white font-medium rounded-lg transition-colors"
        >
          Comprar entradas{ticketPrice ? ` - $${ticketPrice}` : ''}
        </a>
      )}

      {artists.length > 0 && (
        <div class="mt-10">
          <h2 class="text-xl font-semibold mb-3">Artistas</h2>
          <ul class="list-disc list-inside text-gray-600">
            {artists.map((artist) => <li>{artist}</li>)}
          </ul>
        </div>
      )}

      {program.length > 0 && (
        <div class="mt-10">
          <h2 class="text-xl font-semibold mb-3">Programa</h2>
          <ul class="space-y-2">
            {program.map((item) => (
              <li class="text-gray-600">
                <span class="font-medium text-gray-900">{item.composer}</span> — {item.work}
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="mt-10 prose prose-gray max-w-none">
        <Content />
      </div>
    </div>
  </article>
</Base>
